{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base"
  ],
  "regexManagers": [
    {
      "fileMatch": [
        ".*"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[^\\s]+)(?: registryUrl=(?<registryUrl>[^\\s]+))?(?: packageName=(?<packageName>[^\\s]+))?\\s.+?_VERSION=\"?(?<currentValue>.+?)\"?\\s"
      ]
    }
  ]
}
